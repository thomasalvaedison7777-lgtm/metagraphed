{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metagraph.sh/schemas/components/06-health.schema.json",
  "title": "Metagraphed OpenAPI components 06-health",
  "type": "object",
  "components": {
    "schemas": {
      "HealthSurface": {
        "type": "object",
        "required": ["surface_id", "netuid", "status", "classification", "url"],
        "properties": {
          "auth_required": {
            "type": "boolean"
          },
          "surface_id": {
            "type": "string"
          },
          "netuid": {
            "type": "integer",
            "minimum": 0
          },
          "subnet_name": {
            "type": "string"
          },
          "subnet_slug": {
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/SurfaceKind"
          },
          "provider": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "classification": {
            "$ref": "#/components/schemas/Classification"
          },
          "content_type": {
            "type": ["string", "null"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "latency_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "method_tested": {
            "type": "string"
          },
          "private_redirect_blocked": {
            "type": "boolean"
          },
          "public_safe": {
            "type": "boolean"
          },
          "redirect_target": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "status_code": {
            "type": ["integer", "null"]
          },
          "last_checked": {
            "type": ["string", "null"]
          },
          "last_ok": {
            "type": ["string", "null"]
          },
          "verified_at": {
            "type": ["string", "null"]
          },
          "error": {
            "type": ["string", "null"]
          },
          "error_class": {
            "type": ["string", "null"]
          },
          "uptime_sample_ratio": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "archive_support": {
            "type": ["boolean", "null"]
          },
          "latest_block": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "method_results": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "methods_supported": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": {
                  "type": "boolean"
                }
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "rpc_method_count": {
            "type": ["integer", "null"],
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "HealthHistorySurface": {
        "type": "object",
        "required": [
          "surface_id",
          "netuid",
          "kind",
          "provider",
          "status",
          "classification"
        ],
        "properties": {
          "surface_id": {
            "type": "string"
          },
          "netuid": {
            "type": "integer",
            "minimum": 0
          },
          "kind": {
            "$ref": "#/components/schemas/SurfaceKind"
          },
          "provider": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "classification": {
            "$ref": "#/components/schemas/Classification"
          },
          "latency_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "status_code": {
            "type": ["integer", "null"]
          },
          "last_checked": {
            "type": ["string", "null"]
          },
          "last_ok": {
            "type": ["string", "null"]
          },
          "verified_at": {
            "type": ["string", "null"]
          },
          "error_class": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      },
      "HealthSubnetSummary": {
        "type": "object",
        "required": [
          "netuid",
          "slug",
          "name",
          "status",
          "surface_count",
          "ok_count",
          "failed_count",
          "degraded_count",
          "unknown_count"
        ],
        "properties": {
          "netuid": {
            "type": "integer",
            "minimum": 0
          },
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "surface_count": {
            "type": "integer",
            "minimum": 0
          },
          "ok_count": {
            "type": "integer",
            "minimum": 0
          },
          "failed_count": {
            "type": "integer",
            "minimum": 0
          },
          "degraded_count": {
            "type": "integer",
            "minimum": 0
          },
          "unknown_count": {
            "type": "integer",
            "minimum": 0
          },
          "last_checked": {
            "type": ["string", "null"]
          },
          "last_ok": {
            "type": ["string", "null"]
          },
          "avg_latency_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "HealthLatestArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["observed_at", "summary", "surfaces"],
            "properties": {
              "observed_at": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "summary": {
                "type": "object",
                "additionalProperties": true
              },
              "surfaces": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/HealthSurface"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "HealthSummaryArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["global", "subnets"],
            "properties": {
              "global": {
                "type": "object",
                "additionalProperties": true
              },
              "subnets": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/HealthSubnetSummary"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "HealthHistoryArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["date", "summary", "surfaces"],
            "properties": {
              "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "source": {
                "type": "string"
              },
              "probe_started_at": {
                "type": ["string", "null"]
              },
              "probe_finished_at": {
                "type": ["string", "null"]
              },
              "summary": {
                "type": "object",
                "additionalProperties": true
              },
              "surfaces": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/HealthHistorySurface"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "HealthSubnetArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["netuid", "slug", "name", "summary", "surfaces"],
            "properties": {
              "netuid": {
                "type": "integer",
                "minimum": 0
              },
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "summary": {
                "$ref": "#/components/schemas/HealthSubnetSummary"
              },
              "surfaces": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/HealthSurface"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "HealthBadgeArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": [
              "netuid",
              "label",
              "message",
              "status",
              "color",
              "surface_count"
            ],
            "properties": {
              "netuid": {
                "type": "integer",
                "minimum": 0
              },
              "label": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "status": {
                "$ref": "#/components/schemas/HealthStatus"
              },
              "color": {
                "type": "string"
              },
              "surface_count": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        ]
      }
    }
  }
}
