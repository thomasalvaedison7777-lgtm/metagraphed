# Bulk dataset exports (CSV/JSON) — DATA-derived from the registry, regenerated +
# served as static assets on every build/deploy. Never commit: they re-drift on
# every data refresh and repeatedly red-lined the "fresh artifacts" gate. Also
# excluded from that gate in validate.yml so a stale-based enrich PR re-tracking
# them can't turn CI red. (Contract artifacts stay committed + gated.)
public/datasets/

# Local/private automation implementation details
private/
ops/private/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

